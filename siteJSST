<script>
function showSection(id, el) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
  document.getElementById('section-' + id).classList.add('active');
  if (el) {
    el.classList.add('active');
  } else {
    const links = ['accueil','convocations','boutique','histoire','club','sponsors','licence'];
    const idx = links.indexOf(id);
    if (idx >= 0) document.querySelectorAll('.nav-link')[idx].classList.add('active');
  }
  window.scrollTo(0, 0);
}

function toggleConvoc(id, btn) {
  const detail = document.getElementById('convoc-' + id);
  const isOpen = detail.classList.contains('open');
  document.querySelectorAll('.convoc-detail').forEach(d => d.classList.remove('open'));
  document.querySelectorAll('.convoc-btn').forEach(b => b.classList.remove('open'));
  if (!isOpen) {
    detail.classList.add('open');
    btn.classList.add('open');
  }
}

function submitLicence() {
  const msg = document.getElementById('success-msg');
  msg.style.display = 'block';
  setTimeout(() => msg.style.display = 'none', 5000);
}

document.querySelectorAll('.btn-add').forEach(btn => {
  btn.addEventListener('click', () => {
    btn.textContent = 'Ajouté !';
    btn.style.background = '#1d6e34';
    setTimeout(() => { btn.textContent = 'Ajouter'; btn.style.background = ''; }, 2000);
  });
});
</script>
